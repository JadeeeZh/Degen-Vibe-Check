# Optional real social sources.
#
# X recent search bearer token.
# Used for approximate 24h / 7d mention counts with capped pagination.
# X_API_BEARER_TOKEN=
#
# Neynar v2 API key for Farcaster cast search.
# NEYNAR_API_KEY=
#
# Optional request caps to control cost / latency.
# Because X recent search is usage-metered, the default implementation is conservative.
# X_SEARCH_MAX_PAGES=1
# NEYNAR_SEARCH_MAX_PAGES=2
#
# Optional GoPlus bearer token for malicious-address checks on issuer wallets.
# Without this, issuer history still uses explorer-sampled prior launches but address-risk flags stay degraded.
# GOPLUS_ACCESS_TOKEN=
#
# Optional explorer sampling caps for issuer prior-launch lookups.
# BLOCKSCOUT_MAX_PAGES=3
# PRIOR_LAUNCH_SAMPLE_LIMIT=5
